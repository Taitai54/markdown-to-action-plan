# API Keys — at least one is required
OPENAI_API_KEY=
PERPLEXITY_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Optional — OpenRouter model override (default: openai/gpt-4o-mini)
OPENROUTER_MODEL=

# Optional — require x-api-secret or Authorization: Bearer on /api/generate and /api/export/docx
# GENERATE_API_SECRET=

# Optional — limits (defaults shown)
# MAX_MARKDOWN_CHARS=200000
# MAX_DOCX_HTML_CHARS=2000000
# LLM_REQUEST_TIMEOUT_MS=180000
